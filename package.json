{
  "name": "hanako-rss",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenHanako community plugin for RSS / Atom subscription management",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "smoke": "node ./tests/smoke.mjs",
    "package-release": "python3 ./scripts/package_release.py",
    "package-release:smoke": "python3 ./scripts/package_release.py --smoke"
  },
  "dependencies": {
    "fast-xml-parser": "5.5.9"
  }
}
